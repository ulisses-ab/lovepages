VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: set this to enable subdomain-based public URLs (e.g. mypage.lovepages.com)
# Leave blank to use path-based URLs instead (/p/mypage)
VITE_BASE_DOMAIN=

# Stripe — client-side (publishable key, safe to expose)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe — server-side (Edge Function secrets, set via Supabase dashboard or CLI)
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# Mercado Pago — server-side (Edge Function secret, set via Supabase dashboard or CLI)
# Used for Brazilian users instead of Stripe
# Get your access token at: mercadopago.com.br → Suas integrações → Credenciais
# MERCADO_PAGO_ACCESS_TOKEN=APP_USR-...

# OpenAI — server-side (Edge Function secret, set via Supabase dashboard or CLI)
# Used by the AI page generator (generate-page edge function)
# Get your key at: platform.openai.com → API Keys
# OPENAI_API_KEY=sk-...
